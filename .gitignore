# DevTopology generated artifacts
.index/

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/

# OS / editor
.DS_Store
.cache/

# JS / web client build outputs
node_modules/
web/node_modules/
web/dist/
web/.svelte-kit/
dist/
build/

# Product data — derived nightly, never committed (Stooq/Nasdaq/EDGAR pulls,
# DuckDB working files, exported Parquet/JSON shards). See docs/PRD.md.
data/
*.duckdb
*.duckdb.wal
*.parquet

# Task isolation worktrees
.worktrees/

# M4.5 LLM theme candidates — intermediate extractor output, re-runnable from the
# 10-K (make theme-extract). Only the human-approved files (themes/approved/*.json)
# are the durable SoT and stay in git; the approved file already carries the LLM
# provenance (model, filing, llm_exposure per row). See themes/extract.py / review.py.
themes/candidates/

# Cloudflare Pages / wrangler (D.3). Local deploy state + local secret file —
# the API token lives only in a GitHub Actions secret or `wrangler login` creds,
# never in the repo. See docs/runtime/Deploy-Pages-Runbook.md.
.wrangler/
.dev.vars
.dev.vars.*

# Credential-bearing paths. The .example templates under docs/runtime/ stay in git;
# real env files, real inventories, mirrors, and incoming-staging files do not.
# See docs/runtime/Credentials-Management.md.
**/secrets/
**/*.env
!**/*.env.example
!**/.env.example
docs/runtime/Env-Registry.md
docs/runtime/Secrets-Inventory.yaml

# Multi-agent task progress docs — transient cross-worktree coordination state
# (one .md per task, read/written by subagents via the repo-root ABSOLUTE path).
# Not durable artifacts: deliverables live in each task's PR / main. The doc's own
# header explains the mechanism. See CLAUDE.md 三层状态协议 (state = protocol, not log).
docs/progress/
